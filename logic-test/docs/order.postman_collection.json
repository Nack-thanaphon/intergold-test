      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"order\": {\n    \"customer_id\": \"C001\",\n    \"order_type\": \"transfer\",\n    \"quantity\": 1.0,\n    \"quoted_price\": 30000\n  }\n}"
        },
        "url": {
          "raw": "http://localhost:3000/validate-order",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["validate-order"]
