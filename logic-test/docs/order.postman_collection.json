{
  "info": {
    "name": "Order Validation API",
    "description": "API สำหรับตรวจสอบความถูกต้องของคำสั่งซื้อขายทองคำ",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["health"]
        }
      }
    },
    {
      "name": "Case 1: Valid Buy Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"order\": {\n    \"customer_id\": \"C001\",\n    \"order_type\": \"buy\",\n    \"quantity\": 1.0,\n    \"quoted_price\": 30150\n  },\n  \"customerBalance\": {\n    \"balance\": 100000\n  },\n  \"currentMarketPrice\": 30000\n}"
        },
        "url": {
          "raw": "http://localhost:3000/validate-order",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["validate-order"]
        },
        "description": "buy, qty 1.0, ราคาปกติ, balance พอ - Expected: PASS"
      }
    },
    {
      "name": "Case 2: Valid Sell Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"order\": {\n    \"customer_id\": \"C001\",\n    \"order_type\": \"sell\",\n    \"quantity\": 0.5,\n    \"quoted_price\": 29700\n  },\n  \"currentMarketPrice\": 30000\n}"
        },
        "url": {
          "raw": "http://localhost:3000/validate-order",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["validate-order"]
        },
        "description": "sell, qty 0.5, ราคาปกติ - Expected: PASS"
      }
    },
