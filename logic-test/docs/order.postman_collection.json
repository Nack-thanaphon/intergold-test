            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"order\": {\n    \"customer_id\": \"C001\",\n    \"order_type\": \"buy\",\n    \"quantity\": 1.0,\n    \"quoted_price\": 31000\n  },\n  \"customerBalance\": {\n    \"balance\": 100000\n  },\n  \"currentMarketPrice\": 30000\n}"
        },
        "url": {
          "raw": "http://localhost:3000/validate-order",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["validate-order"]
        },
        "description": "ราคาห่างจาก market เกิน 2% - expected 30150 but got 31000 - Expected: FAIL"
      }
    },
    {
      "name": "Case 8: Price At 2% Boundary",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"order\": {\n    \"customer_id\": \"C001\",\n    \"order_type\": \"buy\",\n    \"quantity\": 1.0,\n    \"quoted_price\": 30753\n  },\n  \"customerBalance\": {\n    \"balance\": 100000\n  },\n  \"currentMarketPrice\": 30000\n}"
        },
        "url": {
          "raw": "http://localhost:3000/validate-order",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["validate-order"]
        },
        "description": "ราคาพอดีขอบ 2% - 30150 + 2% = 30753 - Expected: PASS"
      }
    },
    {
      "name": "Case 9: Negative Quantity",
      "request": {
        "method": "POST",
        "header": [
          {
