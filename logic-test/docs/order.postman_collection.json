        "body": {
          "mode": "raw",
          "raw": "{\n  \"order\": {\n    \"customer_id\": \"C001\",\n    \"order_type\": \"buy\",\n    \"quantity\": -1.0,\n    \"quoted_price\": 30000\n  }\n}"
