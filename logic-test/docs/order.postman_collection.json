        "url": {
          "raw": "http://localhost:3000/validate-order",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["validate-order"]
        },
        "description": "qty ติดลบ - Expected: FAIL"
      }
    },
    {
      "name": "Case 10: Sell Does Not Check Balance",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"order\": {\n    \"customer_id\": \"C002\",\n    \"order_type\": \"sell\",\n    \"quantity\": 1.0,\n    \"quoted_price\": 29700\n  },\n  \"currentMarketPrice\": 30000\n}"
        },
        "url": {
          "raw": "http://localhost:3000/validate-order",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["validate-order"]
