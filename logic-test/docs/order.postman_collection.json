    {
      "name": "Case 6: Insufficient Balance",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"order\": {\n    \"customer_id\": \"C002\",\n    \"order_type\": \"buy\",\n    \"quantity\": 5.0,\n    \"quoted_price\": 30150\n  },\n  \"customerBalance\": {\n    \"balance\": 50000\n  },\n  \"currentMarketPrice\": 30000\n}"
        },
        "url": {
          "raw": "http://localhost:3000/validate-order",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["validate-order"]
